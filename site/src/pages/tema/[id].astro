---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StoryCard from '../../components/StoryCard.astro';
import { href, SEG, LABEL } from '../../lib/site';
import { allStories, storiesReferencing, labelMap } from '../../lib/queries';

export async function getStaticPaths() {
  const themes = await getCollection('themes');
  return themes.map((t) => ({ params: { id: t.id }, props: { entity: t } }));
}

const { entity } = Astro.props;
const d = entity.data;
const stories = await allStories();
const refs = storiesReferencing(stories, 'themes', entity.id);
const volumes = await labelMap('volumes');
---

<Base title={`${d.label} — téma`} description={d.description}>
  <div class="crumbs"><a href={href('/')}>Főoldal</a> › {LABEL.themes} › {d.label}</div>
  <h1>{d.label}</h1>
  <p class="muted">Téma · {refs.length} mese</p>
  {d.description && <p style="max-width:60ch">{d.description}</p>}

  <div class="section-title"><h2>Ehhez a témához tartozó mesék</h2><span class="count">{refs.length} db</span></div>
  <div class="grid">
    {refs.map((s) => <StoryCard story={s} volumeName={volumes.get(s.data.volume.id)} />)}
  </div>
</Base>
