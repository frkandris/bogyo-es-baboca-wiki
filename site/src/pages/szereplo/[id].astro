---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StoryCard from '../../components/StoryCard.astro';
import { href, SEG, LABEL } from '../../lib/site';
import { allStories, storiesReferencing, labelMap } from '../../lib/queries';

export async function getStaticPaths() {
  const chars = await getCollection('characters');
  return chars.map((c) => ({ params: { id: c.id }, props: { entity: c } }));
}

const { entity } = Astro.props;
const d = entity.data;
const kindLabel: Record<string, string> = { person: 'Szereplő', animal: 'Állat', toy: 'Játék', other: 'Egyéb' };

const stories = await allStories();
const refs = storiesReferencing(stories, 'characters', entity.id);
const volumes = await labelMap('volumes');
---

<Base title={d.name} description={d.description}>
  <div class="crumbs"><a href={href('/')}>Főoldal</a> › <a href={href(`/${SEG.character}`)}>{LABEL.characters}</a> › {d.name}</div>
  <h1>{d.name}</h1>
  <p class="muted">{kindLabel[d.kind] ?? 'Szereplő'} · {refs.length} mesében szerepel</p>
  {d.description && <p style="max-width:60ch">{d.description}</p>}

  <div class="section-title"><h2>Mesék {d.name} szereplésével</h2><span class="count">{refs.length} db</span></div>
  <div class="grid">
    {refs.map((s) => <StoryCard story={s} volumeName={volumes.get(s.data.volume.id)} />)}
  </div>
</Base>
